# OpenAI API key — required for LLM-as-judge evaluation
OPENAI_API_KEY=sk-your-key-here

# Model to use for LLM judge (default: gpt-4o-mini)
ML_EVAL_JUDGE_MODEL=gpt-4o-mini

# SQLite database path (default: ./ml_eval_results.db)
ML_EVAL_DB_PATH=./ml_eval_results.db

# Sentence transformer model for semantic similarity (default: all-MiniLM-L6-v2)
ML_EVAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# API server settings
ML_EVAL_HOST=0.0.0.0
ML_EVAL_PORT=8000
